# For LOCAL development (SQLite):
DATABASE_URL="file:./prisma/dev.db"

# For PRODUCTION / Vercel (PostgreSQL via Neon):
# Do NOT put your production DATABASE_URL here!
# Set it in Vercel dashboard: https://vercel.com/dashboard → Project → Settings → Environment Variables
# DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/discipline-db?sslmode=require"

# Change this to a random string in production (min 32 chars)
JWT_SECRET=change-this-to-a-random-secret-in-production
